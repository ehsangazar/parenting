# Frontend Environment Variables
# Copy this file to .env and fill in your values
# Note: Vite requires the VITE_ prefix for environment variables

# API URL — points at parenting-backend.
# Local dev: http://localhost:4000
# Production: https://parenting-backend.gazar.dev
VITE_API_URL=http://localhost:4000

# Optional: `<loc>` origin for http://localhost:5173/sitemap.xml in dev (default http://localhost:<port>)
# VITE_SITEMAP_BASE_URL=http://127.0.0.1:5173

# Google OAuth (optional - omit to hide Google sign-in)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Sentry (optional)
VITE_SENTRY_DSN=

# Google Analytics tag id (optional)
VITE_GOOGLE_TAG_ID=

# OpenPanel analytics (optional)
VITE_PUBLIC_OPENPANEL_CLIENT_ID=
VITE_PUBLIC_OPENPANEL_API_URL=https://openpanel-api.gazar.dev
